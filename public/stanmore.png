<script>
function waitForElement(selector, callback) {
    const observer = new MutationObserver((mutations, observer) => {
        const element = document.querySelector(selector);
        if (element) {
            observer.disconnect();
            callback(element);
        }
    });

    observer.observe(document.body, {
        childList: true,
        subtree: true,
    });
}		
	
jQuery( document ).ready(function() {

	waitForElement('.investi-announcements-accordion table', (element) => {
		
		jQuery( ".investi-announcements-accordion table" ).each(function( index  ) {
    	var rows = jQuery("tr", this).length;
      jQuery(this).prev().append("<span> - <span class='row-num'>" + rows + "</span> results</span>");
  	});
    
    jQuery('.investi-searchbox').on('input',function(e){
        var count = 0;
				setTimeout( function() {
          jQuery( ".investi-announcements-accordion table" ).each(function( index  ) {
						count = 0;
						jQuery("tr", this).each(function( index  ) {
							if (jQuery(this).css('display') != 'none')
							{
								 count++;
							}
						});
						jQuery(this).prev().find(".row-num").text(count);
          });
        }, 500);
    });
	});
});
</script>

