				<div class="elementor-element elementor-element-73070c0 elementor-widget elementor-widget-image" data-id="73070c0" data-element_type="widget" data-widget_type="image.default">
															<img decoding="async" width="1200" height="839" src="/wp-content/uploads/2025/08/Discover-our-vision-mission-and-values.jpg" class="attachment-full size-full wp-image-81" alt="" srcset="/wp-content/uploads/2025/08/Discover-our-vision-mission-and-values.jpg 1200w, /wp-content/uploads/2025/08/Discover-our-vision-mission-and-values-300x210.jpg 300w, /wp-content/uploads/2025/08/Discover-our-vision-mission-and-values-1024x716.jpg 1024w, /wp-content/uploads/2025/08/Discover-our-vision-mission-and-values-768x537.jpg 768w" sizes="(max-width: 1200px) 100vw, 1200px" />															</div>
				<div class="elementor-element elementor-element-1010215 elementor-widget__width-initial elementor-widget elementor-widget-heading" data-id="1010215" data-element_type="widget" data-widget_type="heading.default">
					<h5 class="elementor-heading-title elementor-size-default">Discover our Vision, Mission and Values.</h5>				</div>
				<div class="elementor-element elementor-element-6d698b5 elementor-view-framed elementor-shape-circle elementor-widget elementor-widget-icon" data-id="6d698b5" data-element_type="widget" data-widget_type="icon.default">
